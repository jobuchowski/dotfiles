#!/bin/bash

rofi_dir="$HOME/.config/rofi"
bin_dir="$HOME/.local/bin"

opt_bluetooth="’Ŗō";
opt_wifi="’ć½";
opt_displays="’ē¼";
opt_sound="’Ć©";
opt_about_system="’üÜ";
opt_usb="’ć”";

rofi_cmd() {
	rofi -dmenu \
		-p "Options" \
		-mesg "Options" \
        -theme ${dir}/widgets/options.rasi
}

echo_options() {
    echo -e "$opt_bluetooth\n$opt_wifi\n$opt_displays\n$opt_sound\n$opt_about_system\n$opt_usb"
}

run_rofi() {
    echo_options | rofi_cmd
}

choice=$(run_rofi)
case ${choice} in
    $opt_bluetooth)
        $bin_dir/seed-exec-floating-window kitty -o confirm_os_window_close=0 bluetui
        ;;
    $opt_wifi)
        $bin_dir/seed-exec-floating-window nm-connection-editor
        ;;
    $opt_displays)
        $bin_dir/seed-exec-floating-window nwg-displays
        ;;
    $opt_sound)
        $bin_dir/seed-exec-floating-window pavucontrol
        ;;
    $opt_about_system)
        $bin_dir/seed-exec-floating-window kitty bash -c "fastfetch; read -n 1"
        ;;
    $opt_usb)
        hyprctl dispatch exec "[float; center] quickshell -p $HOME/.config/quickshell/apps/usb"
        ;;
esac


